#!/usr/bin/env bash
#MISE description="Upgrade all packages, tools, plugins, and extensions"
#MISE depends=["bootstrap"]
#
# Ongoing-update entry point (replaces the old system-sync script): run the
# bootstrap steps (via the dependency above), then upgrade everything.
set -e

mise self-update --yes || true
mise bootstrap packages upgrade
mise bootstrap packages prune --yes
mise upgrade --yes
mise prune --yes
# No `brew upgrade` here: formulae AND casks are mise-managed via
# [bootstrap.packages], and `mise bootstrap packages upgrade` (above) also
# upgrades the transitive dependency closure — brew itself has nothing left
# to upgrade (and `brew upgrade --cask` would fight mise's Caskroom layout).
nvim --headless "+Lazy! update" +qa || true # upgrade nvim plugins, refresh lazy-lock.json
