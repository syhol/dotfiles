#!/usr/bin/env bash
#MISE description="Install/update VS Code extensions from .config/vscode/extensions.txt"
#
# Declarative install: every extension listed in ~/.config/vscode/extensions.txt
# is installed (or updated to latest, via --force). Lines may carry a trailing
# "# comment"; blank lines and full-line comments are ignored.
set -e

if ! command -v code >/dev/null 2>&1; then
  echo "code CLI not found; skipping VS Code extensions" >&2
  exit 0
fi

list="$HOME/.config/vscode/extensions.txt"

# Build a single invocation: code --install-extension A --install-extension B ...
# This starts the code CLI once instead of once per extension.
args=()
while IFS= read -r ext; do
  [ -n "$ext" ] && args+=(--install-extension "$ext")
done < <(grep -vE '^[[:space:]]*(#|$)' "$list" | awk '{print $1}')

[ ${#args[@]} -eq 0 ] && exit 0
code "${args[@]}" --update-extensions --force
