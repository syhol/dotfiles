#!/usr/bin/env bash
#MISE description="List files in symlink-each dotfile dirs that mise doesn't manage"
#
# For every [dotfiles] entry with mode = symlink-each, walk the live target dir
# and report any leaf that ISN'T a symlink into the dotfiles repo — i.e. real
# files, runtime dirs, or foreign symlinks (app state, plugin installs, caches,
# secrets). copy-mode dirs (gh, k9s) are excluded; "unmanaged" means something
# different there.
set -euo pipefail

# Repo root, derived from the mise.toml symlink (no hardcoded path).
repo=$(readlink "$HOME/.config/mise/mise.toml" | sed 's#/\.config/mise/mise\.toml$##')

mise dotfiles status -J 2>/dev/null \
  | jq -r '.files[] | select(.mode=="symlink-each") | .target' \
  | while IFS= read -r target; do
      dir="${target/#\~/$HOME}"
      [ -d "$dir" ] || continue
      unmanaged=$(
        find "$dir" -mindepth 1 \( -type f -o -type l \) 2>/dev/null | while IFS= read -r f; do
          if [ -L "$f" ]; then
            case "$(readlink "$f")" in "$repo"/*) continue ;; esac
          fi
          printf '%s\n' "${f#"$dir"/}"
        done | sort
      )
      n=$(printf '%s' "$unmanaged" | grep -c . || true)
      if [ "$n" -eq 0 ]; then
        printf '\033[32m✓ %s\033[0m  (fully managed)\n' "$target"
      else
        printf '\033[33m● %s\033[0m  (%s unmanaged)\n' "$target" "$n"
        printf '%s\n' "$unmanaged" | sed 's/^/    /'
      fi
    done
