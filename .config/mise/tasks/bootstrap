#!/usr/bin/env bash
#MISE description="Install VS Code extensions, plugins, and shell completions"
#
# Runs at the end of `mise bootstrap` (step 8), with tools on PATH. Covers
# everything the declarative sections can't: VS Code extensions, helm/gh
# plugins, yazi packages, bat cache, shell plugins. (Casks live in
# [bootstrap.packages] as brew-cask: entries — no Brewfile anymore.)
set -e

# Homebrew itself (the prefix and the `brew` CLI) is still assumed by the
# brew:/brew-cask: bootstrap packages and day-to-day use. Install if missing.
if ! command -v brew >/dev/null 2>&1; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$(/opt/homebrew/bin/brew shellenv)"

# VS Code extensions (mise installed the `code` CLI via the visual-studio-code cask)
mise run system:vscode-extensions

helm plugin install https://github.com/databus23/helm-diff || true
helm plugin update diff || true
gh extension install dlvhdr/gh-dash || true
gh extension upgrade --all || true
ya pkg install || true
nvim --headless "+Lazy! restore" +qa || true # install nvim plugins at locked versions
bat cache --build
~/.config/bash/plugins.bash sync
~/.config/fish/plugins.fish sync
~/.config/zsh/plugins.zsh sync
touch ~/.config/shell/secrets.sh
