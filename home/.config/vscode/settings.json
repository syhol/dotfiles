{
	"editor.formatOnSave": true,
	"files.autoSave": "onFocusChange",
	"editor.fontFamily": "JetBrainsMono NFM, MesloLGSDZ Nerd Font Mono, Menlo, Monaco, 'Courier New', monospace",
	"editor.fontSize": 13,
	"terminal.integrated.fontFamily": "JetBrainsMono NFM",
	"terminal.integrated.fontSize": 13,
	"excalidraw.theme": "auto",
	"deno.cacheOnSave": true,
	"redhat.telemetry.enabled": false,
	"diffEditor.ignoreTrimWhitespace": false,
	"editor.renderFinalNewline": "off",
	"files.insertFinalNewline": true,
	// "editor.rulers": [80, 120],
	"terminal.integrated.defaultProfile.osx": "fish",
	"terminal.integrated.profiles.osx": {
		"bash": {
			"path": "bash",
			"args": ["-l"],
			"icon": "terminal-bash"
		},
		"zsh": {
			"path": "zsh",
			"args": ["-l"]
		},
		"fish": {
			"path": "fish",
			"args": ["-l"]
		}
	},
	"terminal.integrated.shellIntegration.enabled": false,
	"gitlens.plusFeatures.enabled": false,
	"docker.extension.enableComposeLanguageServer": false,
	"workbench.colorTheme": "Catppuccin Macchiato",
	"workbench.sideBar.location": "right",
	"editor.dragAndDrop": false,
	"zenMode.fullScreen": false,
	"editor.unicodeHighlight.nonBasicASCII": false,
	"editor.unicodeHighlight.invisibleCharacters": false,
	"editor.unicodeHighlight.ambiguousCharacters": false,
	"claudeCode.preferredLocation": "panel",
	"claudeCode.selectedModel": "opus",
	"json.schemaDownload.trustedDomains": {
		"https://schemastore.azurewebsites.net/": true,
		"https://raw.githubusercontent.com/": true,
		"https://www.schemastore.org/": true,
		"https://json.schemastore.org/": true,
		"https://json-schema.org/": true,
		"https://biomejs.dev": true,
		"https://plugins.dprint.dev": true
	},
	"terminal.integrated.enableKittyKeyboardProtocol": false,
	"aikido.coreUrl": "https://ide.aikido.dev"
}
